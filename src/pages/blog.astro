---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import "../styles/text.css";
import PostPreview from "../components/PostPreview.astro";
import RssIcon from "../components/RssIcon.astro";

const posts = (await getCollection("markdownPosts"))
	.sort((a, b) => compareByPublishDate(a, b))
	.filter((post) => post.data.public);

const years: number[] = [];
posts.forEach((post) => {
	if (yearNotYetAdded(years, post)) {
		years.push(post.data.published!.getFullYear());
	}
});

export function compareByPublishDate(a: any, b: any) {
	return (
		(b.data.published?.valueOf() ?? 0) - (a.data.published?.valueOf() ?? 0)
	);
}

function yearNotYetAdded(years: number[], post: any) {
	return (
		post.data.published && !years.includes(post.data.published.getFullYear())
	);
}
---

<Layout title="Blog" description="Blog posts">
	<main>
		<h1>
			Posts <RssIcon />
		</h1>

		<ul>
			{
				posts.map((post) => (
					<li>
						<PostPreview post={post} />
					</li>
				))
			}
		</ul>
	</main>

	<style is:global>
		body::before {
			content: "";
			width: 95ch;
			height: 200vh;
			display: block;
			background: var(--base);
			position: fixed;
			z-index: -8;
			margin: -1rem 0;
			margin-left: -1px;

			border: 1px solid var(--accent);
			border-top: 0;
			border-bottom: 0;
		}

		body {
			padding-top: 1rem;

			margin: 0 auto;
			width: 95ch;
			background: var(--base);

			border: 1px solid var(--accent);
			border-top: 0;
			border-bottom: 0;
		}

		main {
			h1 {
				margin-top: 0;
				display: flex;
				justify-content: space-between;
			}

			ul {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: row;
				flex-wrap: wrap;
				align-content: start;
				gap: 1rem;
				margin: 1rem;
			}

			li {
				flex: 1 1 20rem;
				max-width: calc(50% - 0.5rem);
				background: var(--base-above);
			}

			@media screen and (max-width: 35rem) {
				li {
					max-width: 100%;
				}
			}

			#rss {
				svg {
					width: 2rem;
					height: 2rem;
				}
			}
		}

		@media screen and (max-width: calc(95ch + 2rem)) {
			body, body::before {
				width: 100% !important;
				border: 0;
				margin-left: 0;
				margin-right: 0;
			}
		}
	</style>
</Layout>
