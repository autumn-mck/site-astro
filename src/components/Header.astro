---
import { Image } from "astro:assets";

import ico from "./ico.png";
---

<header>
	<a href="/"><Image src={ico} alt="" /></a>

	<nav>
		<ul>
			<li><a href="/blog">Blog</a></li>
			<li><a href="/projects">Projects</a></li>
			<li><a href="/uses">Uses</a></li>
		</ul>
	</nav>
</header>

<style is:global>
	header {
		max-width: 95ch;
		margin: 0 auto;
		margin-bottom: 1rem;

		a:has(img),
		img {
			height: 2rem;
			width: auto;
			padding: 0;
		}

		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-left: 1.5rem;
		padding-right: 1.5rem;

		a {
			text-decoration: none;
			font-weight: bold;
			color: transparent;

			transition: color 0.2s ease-out;

			position: relative;
			padding: 0.1em 0;

			&:hover {
				text-decoration: none;
				color: var(--accent);

				&::after {
					transform: scale(1);
				}
			}

			&::after {
				content: "";
				position: absolute;
				bottom: 0;
				left: 0;
				width: 100%;
				height: 0.1em;
				background-color: var(--accent);
				opacity: 0;
				transition:
					opacity 300ms,
					transform 300ms;
				opacity: 1;
				transform: scaleX(0);
				transform-origin: center;
			}
		}
	}

	nav ul {
		list-style: none;
		display: flex;
		margin: 0;
		padding: 0;
		text-transform: lowercase;

		color: transparent;
		background: linear-gradient(to right, #edd0ee, #beabee);

		background-clip: text;

		li:not(:last-child)::after {
			content: "∗";
			margin: 0 0.3rem;
			font-weight: bold;
			color: var(--text);
		}
	}
</style>
